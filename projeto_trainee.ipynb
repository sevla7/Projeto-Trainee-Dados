      "source": [
        "quality = pd.DataFrame({\n",
        "    'tipo': train_df.dtypes.astype(str),\n",
        "    'nulos': train_df.isna().sum(),\n",
        "    'nulos_pct': (train_df.isna().mean()*100).round(2),\n",
        "    'unicos': train_df.nunique()\n",
        "}).sort_values('nulos_pct', ascending=False)\n",
        "quality.head(20)"
      ]
    },
